# Docker Compose environment overrides for Twilight.
# Copy to the repository root as .env before running docker compose.

TZ=Asia/Shanghai
WEBUI_PORT=3000
BACKEND_URL=http://twilight:5000

# Change these before production deployment.
POSTGRES_PASSWORD=<CHANGE_ME_POSTGRES_PASSWORD>
BOT_INTERNAL_SECRET=<CHANGE_ME_RANDOM_SECRET>

# Comma-separated usernames that should become administrators after registration.
ADMIN_USERNAMES=admin
SITE_NAME=Twilight
LOG_LEVEL=info
RUNTIME_LOG_LIMIT=5000
