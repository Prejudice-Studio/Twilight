{
  "name": "twilight-webui",
  "version": "0.0.6",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
