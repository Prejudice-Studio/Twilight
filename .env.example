# =========== Global 全局配置 ===========
# ⚠️  本文件仅作为环境变量模板。
# 部署前必须把所有 <PLACEHOLDER> 占位符替换为高熵随机值，禁止把本文件直接复制成生产 .env。
# 任何示例字符串（your_*, <PLACEHOLDER>）一旦上线即视为弱凭据。
TWILIGHT_LOGGING=true
TWILIGHT_LOG_LEVEL=20
TWILIGHT_SQLALCHEMY_LOG=false
TWILIGHT_MAX_RETRY=3

# Redis 连接串（强烈建议生产环境配置）
# 用途：会话快速缓存 + 速率限制分布式计数
# 即使配置了 Redis，会话仍会持久化到 PostgreSQL，确保 Redis/进程重启后自动恢复
# 格式：redis://[:password@]host:port/db
# 无密码示例：redis://127.0.0.1:6379/0
# 有密码示例：redis://:<REDIS_PASSWORD>@127.0.0.1:6379/0
# 自定义端口+密码：redis://:<REDIS_PASSWORD>@127.0.0.1:65520/0
# TLS 加密连接：rediss://:<REDIS_PASSWORD>@redis.example.com:6380/0
TWILIGHT_REDIS_URL=redis://:<REDIS_PASSWORD>@127.0.0.1:6379/0

# TMDB API Key（从 https://www.themoviedb.org/settings/api 获取）
TWILIGHT_GLOBAL_TMDB_API_KEY=<TMDB_API_KEY>

# Bangumi 全局 API Token（可选；不作为点格子用户兜底 Token）
TWILIGHT_GLOBAL_BANGUMI_TOKEN=

# Bangumi 点格子（Emby Webhook）
# 生成示例：openssl rand -hex 32
TWILIGHT_BANGUMISYNC_ENABLED=false
TWILIGHT_BANGUMISYNC_WEBHOOK_SECRET=<BANGUMI_WEBHOOK_SECRET>
TWILIGHT_BANGUMISYNC_MIN_PROGRESS_PERCENT=80

# ========== 数据库配置 ==========
# 存储后端：postgres（推荐）或 json
TWILIGHT_DATABASE_DRIVER=postgres
# 完整 PostgreSQL DSN（优先于分项配置）
# TWILIGHT_DATABASE_URL=postgres://twilight:<POSTGRES_PASSWORD>@127.0.0.1:5432/twilight?sslmode=disable
# 分项配置（当 DATABASE_URL 为空时使用）
TWILIGHT_POSTGRES_HOST=127.0.0.1
TWILIGHT_POSTGRES_PORT=5432
TWILIGHT_POSTGRES_USER=twilight
TWILIGHT_POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
TWILIGHT_POSTGRES_DATABASE=twilight
TWILIGHT_POSTGRES_SSLMODE=disable

# ========== Emby 配置 ==========
TWILIGHT_EMBY_URL=http://127.0.0.1:8096/
TWILIGHT_EMBY_TOKEN=<EMBY_API_TOKEN>

# ========== API 配置 ==========
TWILIGHT_API_HOST=0.0.0.0
TWILIGHT_API_PORT=5000
TWILIGHT_API_DEBUG=false
TWILIGHT_API_TOKEN_EXPIRE=864000
TWILIGHT_API_CORS_ENABLED=true

# ========== Telegram Bot 配置 ==========
TWILIGHT_TELEGRAM_MODE=false
TWILIGHT_TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>

# ========== 积分和注册配置 ==========
TWILIGHT_SAR_SCORE_NAME=暮光币
TWILIGHT_SAR_INVITE_CODE_FORMAT=inv-{random}
TWILIGHT_SAR_REGISTER_MODE=false
TWILIGHT_SAR_SCORE_REGISTER_MODE=false
TWILIGHT_SAR_SCORE_REGISTER_NEED=100

# ========== 设备限制配置 ==========
TWILIGHT_DEVICELIMIT_ENABLED=false
TWILIGHT_DEVICELIMIT_MAX_DEVICES=5
TWILIGHT_DEVICELIMIT_MAX_STREAMS=2

# ========== Webhook 配置 ==========
# 生成示例：openssl rand -hex 32
TWILIGHT_WEBHOOK_ENABLED=false
TWILIGHT_WEBHOOK_SECRET=<WEBHOOK_SECRET>

# ========== 安全配置 ==========
TWILIGHT_SECURITY_LOGIN_FAIL_THRESHOLD=5
TWILIGHT_SECURITY_LOCKOUT_MINUTES=30
# Session cookie Secure 标志：HTTPS 部署必须为 true（默认 true）。
# 仅本地 HTTP 调试时改为 false。生产置 false 等于 session token 明文走线。
TWILIGHT_SESSION_COOKIE_SECURE=true
# 单用户 5 分钟登录尝试上限（IP 桶之外的第二道 throttle）
TWILIGHT_RATE_LIMIT_LOGIN_USER_PER_5M=10
# Bot/外部系统调用内部接口的共享密钥（必须设置高熵随机字符串）
# 生成示例：openssl rand -base64 48
TWILIGHT_BOT_INTERNAL_SECRET=<BOT_INTERNAL_SECRET>

# ========== 定时任务 ==========
TWILIGHT_SCHEDULER_ENABLED=true
TWILIGHT_SCHEDULER_TIMEZONE=Asia/Shanghai
